# --- Meta / Facebook ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v25.0
META_MOCK_MODE=false

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Kampanya hedefi ---
# "awareness": karar motoru satış (purchases) yokluğuna göre pause önermez,
# reach/frequency/CPM'e bakar. "sales": satış/dönüşüm verimliliğine bakar.
CAMPAIGN_OBJECTIVE=awareness

# --- Marka bağlamı (opsiyonel) ---
# Serbest metin: markanın sesi/hedef kitlesi/ton tercihleri. Ayarlanırsa
# karar motorunun sistem promptuna eklenir. Boş bırakılırsa araç
# marka-agnostik kalır.
BRAND_CONTEXT=

# --- Operasyon ---
DRY_RUN=true
KILL_SWITCH=false
RUN_INTERVAL_HOURS=4
LOG_LEVEL=INFO
# "onayli" (varsayılan, güvenli): guardrail'den geçen her aksiyon insan
# onayı bekleyen bir kuyruğa (logs/approval_queue.jsonl) eklenir; masaüstü
# uygulamasındaki "Onay Kuyruğu" sekmesinden onaylanır/reddedilir.
# "tam_otomatik": guardrail'den geçen aksiyonlar onay beklemeden direkt uygulanır.
AUTOMATION_MODE=onayli

# --- Guardrail sabitleri ---
MAX_DAILY_BUDGET_TOTAL=100
MAX_BUDGET_CHANGE_PERCENT=20
MIN_SPEND_BEFORE_ACTION=5
MAX_ACTIONS_PER_RUN=10

# --- Bildirim (opsiyonel) ---
SLACK_WEBHOOK_URL=

# --- Kademeli canlıya alma (FAZ 8, opsiyonel) ---
# Boş bırakılırsa hesaptaki tüm aktif ad set'ler kapsam dahilindedir.
# Doldurulursa sadece adı bu alt dizeyi içeren kampanyalardaki ad set'ler
# işlenir (staged rollout'ta botun etkisini tek bir kampanyaya sınırlamak için).
SCOPE_CAMPAIGN_NAME_FILTER=

# --- Log rotasyonu (FAZ 9, opsiyonel) ---
ACTIONS_LOG_MAX_BYTES=10485760
ACTIONS_LOG_BACKUP_COUNT=5

# --- Token expiry uyarısı (FAZ 9, opsiyonel) ---
TOKEN_EXPIRY_WARN_DAYS=7

# --- Instagram / creative üretimi (FAZ 11, opsiyonel) ---
IG_MOCK_MODE=false
IG_ACCESS_TOKEN=
IG_API_VERSION=v25.0
IG_BUSINESS_ACCOUNT_ID=
IG_MIN_POST_AGE_HOURS=48
IG_TOP_N_POSTS=5
IG_USERNAME=
IG_ONLY_VIDEO_POSTS=false
# IG hesabına bağlı Facebook Page ID'si — Reels'ler için object_story_id
# oluşturmak amacıyla Sayfa feed'inde eşleşen gönderiyi bulmak için gerekli.
META_PAGE_ID=

# --- Kampanya/reklam oluşturma guardrail'leri (FAZ 12, opsiyonel) ---
MAX_NEW_CAMPAIGNS_PER_RUN=1
MAX_NEW_CAMPAIGNS_PER_DAY=3
DEFAULT_NEW_ADSET_DAILY_BUDGET=10
